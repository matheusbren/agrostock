  "license": "ISC",
  "dependencies": {
    "bootstrap": "^5.3.8",
    "jquery": "^3.7.1",
    "jquery-mask-plugin": "^1.14.16"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "json-server": "^1.0.0-beta.3",
    "prettier": "^3.8.2",
    "puppeteer": "^24.42.0",
    "sass": "^1.99.0",
    "sharp": "^0.34.5"
  }
}
